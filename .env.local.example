# ─────────────────────────────────────────────────────────────────────────────
# Rename this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Beehiiv ───────────────────────────────────────────────────────────────────
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Admin passwords ───────────────────────────────────────────────────────────
# Supports multiple passwords — separate with commas (one per team member)
# e.g. ADMIN_KEY=alicespassword,bobspassword,carolspassword
ADMIN_KEY=choose_a_strong_password_here

# ── Admin contact email (shown on "Forgot password" link) ─────────────────────
NEXT_PUBLIC_ADMIN_CONTACT_EMAIL=hello@womenshealth.world
