# ─────────────────────────────────────────────────────────────────────────────
# Rename this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Beehiiv ───────────────────────────────────────────────────────────────────
# Found in: Beehiiv dashboard → Settings → Integrations → API Keys
BEEHIIV_API_KEY=your_beehiiv_api_key_here

# Found in: Beehiiv dashboard → Settings → Publication → Publication ID
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Admin dashboard password ──────────────────────────────────────────────────
# Choose any strong password — this protects your admin page at /admin
ADMIN_KEY=choose_a_strong_password_here
